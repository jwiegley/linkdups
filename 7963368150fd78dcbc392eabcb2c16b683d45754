            "content": "#!/usr/bin/env python3\n\"\"\"Compare benchmark results against a saved baseline.\n\nUsage: check_perf.py <results.json>\n\nFails if any benchmark regresses by more than 5% compared to baseline.\nIf no baseline exists, prints a warning and exits successfully.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport sys\nfrom pathlib import Path\n\nBASELINE_PATH = Path(\".benchmarks/baseline.json\")\nMAX_REGRESSION_PCT = 5.0\n\n\ndef main() -> int:\n    if len(sys.argv) < 2:\n        print(\"Usage: check_perf.py <results.json>\", file=sys.stderr)\n        return 1\n\n    results_path = Path(sys.argv[1])\n\n    if not BASELINE_PATH.exists():\n        print(\n            \"No baseline found. Run:\\n\"\n            \"  PYTHONPATH=src pytest tests/test_benchmark.py \"\n            \"--benchmark-json=.benchmarks/baseline.json\",\n            file=sys.stderr,\n        )\n        return 0\n\n    with open(BASELINE_PATH) as f:\n        baseline = json.load(f)\n    with open(results_path) as f:\n        results = json.load(f)\n\n    baseline_means: dict[str, float] = {\n        b[\"name\"]: b[\"stats\"][\"mean\"] for b in baseline[\"benchmarks\"]\n    }\n    results_means: dict[str, float] = {\n        b[\"name\"]: b[\"stats\"][\"mean\"] for b in results[\"benchmarks\"]\n    }\n\n    failed = False\n    for name, result_mean in results_means.items():\n        if name in baseline_means:\n            baseline_mean = baseline_means[name]\n            if baseline_mean > 0:\n                regression = (result_mean - baseline_mean) / baseline_mean * 100\n            else:\n                regression = 0.0\n\n            if regression > MAX_REGRESSION_PCT:\n                print(\n                    f\"FAIL: {name} regressed by {regression:.1f}% \"\n                    f\"(baseline: {baseline_mean:.6f}s, \"\n                    f\"current: {result_mean:.6f}s)\"\n                )\n                failed = True\n            else:\n                print(f\"OK: {name} ({regression:+.1f}%)\")\n\n    return 1 if failed else 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n",
